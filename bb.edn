{:deps  {outskirtslabs/bb-tasks
         {:git/url "https://github.com/outskirtslabs/bb-tasks"
          :git/sha "e868e28b18a0496ec4d39878f0307cb1df17da22"}}
 :paths []
 :tasks {:requires
         ([babashka.fs :as fs]
          [clojure.string :as str]
          [clojure.pprint :refer [print-table]]
          [babashka.tasks :refer [shell]]
          [ol.bb-tasks.publish-clojars :as publish-clojars])

         :init
         (do
           (def paths ["src" "test" "examples" "native"])
           (def lint-paths ["src" "test" "native" "examples"])
           (defn native-dirs []
             (->> (fs/list-dir "native")
                  (filter fs/directory?)
                  (filter (fn [dir]
                            (fs/exists? (fs/path dir "deps.edn"))))
                  (sort-by str)
                  vec))
           (defn selected-native-dirs []
             (let [selected (set *command-line-args*)]
               (if (seq selected)
                 (->> (native-dirs)
                      (filter (fn [dir]
                                (contains? selected (str (fs/file-name dir)))))
                      vec)
                 (native-dirs))))
           (defn sync-native-versions! []
             (println "syncing native companion versions")
             (shell "clojure" "-T:build" "sync-native-versions"))
           (defn update-native! [dirs]
             (when (seq dirs)
               (println "staging native resources for"
                        (str/join ", " (map (fn [dir]
                                              (str (fs/file-name dir)))
                                            dirs)))
               (shell "clojure"
                      "-T:build"
                      "native-update"
                      ":platforms"
                      (pr-str (mapv (fn [dir]
                                      (keyword (str (fs/file-name dir))))
                                    dirs)))))
           (defn build-native-jars! [dirs]
             (doseq [dir dirs]
               (println "building native jar for" (str (fs/file-name dir)))
               (shell {:dir (str dir)} "clojure" "-T:build" "jar")))
           (defn deploy-native-jars! [dirs]
             (doseq [dir dirs]
               (println "deploying native jar for" (str (fs/file-name dir)))
               (shell {:dir (str dir)} "clojure" "-T:build" "deploy"))))

         dev
         {:doc  "Start a local development server"
          :task (apply clojure "-M:repl/dev:dev" *command-line-args*)}

         test
         {:doc  "Run all tests or specific test suites"
          :task (apply clojure "-M:dev:kaocha" *command-line-args*)}

         fmt
         {:doc  "Format code with cljfmt"
          :task (apply shell "cljfmt --quiet -v fix" (if (seq *command-line-args*) *command-line-args* paths))}

         fmt:check
         {:doc  "Check code formatting without making changes"
          :task (apply shell "cljfmt check " paths)}

         prep
         {:doc  "Prepare Clojure dependencies"
          :task (clojure "-X:deps" "prep" ":aliases" "[:dev :kaocha]")}

         deps-tree
         {:doc  "Show dependency tree"
          :task (clojure "-X:deps tree :aliases '[:dev]'")}

         lint:copy-configs
         {:doc  "Copy clj-kondo configs from dependencies"
          :task (shell "clj-kondo" "--lint" (-> (shell {:out :string} "clojure -Spath -M:test:dev") :out str/trim) "--dependencies" "--copy-configs" "--skip-lint")}

         lint
         {:doc  "Lint code with clj-kondo"
          :task (if (seq *command-line-args*)
                  (apply shell "clj-kondo" "--lint" *command-line-args*)
                  (apply shell "clj-kondo --lint" lint-paths))}

         gen
         {:doc  "Generate enum and operation namespaces from live libvips introspection"
          :task (do
                  (clojure "-M:dev" "-m" "ol.vips.codegen")
                  (shell "cljfmt" "--quiet" "-v" "fix" "src/ol/vips/enums.clj" "src/ol/vips/operations.clj"))}

         native:update
         {:doc  "Download and stage native resources for the selected platforms"
          :task (let [dirs (selected-native-dirs)]
                  (sync-native-versions!)
                  (update-native! dirs))}

         build:native:stage
         {:doc  "Alias for native:update"
          :task (let [dirs (selected-native-dirs)]
                  (sync-native-versions!)
                  (update-native! dirs))}

         clean:native
         {:doc  "Clean staged native resources, companion targets, and native caches"
          :task (do
                  (doseq [dir (native-dirs)]
                    (when (fs/exists? (fs/path dir "resources"))
                      (fs/delete-tree (fs/path dir "resources")))
                    (when (fs/exists? (fs/path dir "target"))
                      (fs/delete-tree (fs/path dir "target"))))
                  (when (fs/exists? "target/native-cache")
                    (fs/delete-tree "target/native-cache")))}

         jar:native
         {:doc  "Build native companion jars for the selected platforms"
          :task (let [dirs (selected-native-dirs)]
                  (sync-native-versions!)
                  (update-native! dirs)
                  (build-native-jars! dirs))}

         qa
         {:doc     "Run full quality assurance: format, lint, and test"
          :depends [fmt lint test]}

         ci
         {:doc     "Run CI checks: test, format check, and lint"
          :depends [test fmt:check lint]}

         jar       {:override-builtin true
                    :depends          [clean]
                    :doc              "Build an jar"
                    :task             (shell "clojure -T:build jar")}

         clean     {:override-builtin true
                    :doc              "Clean build artifacts"
                    :task             (shell "clojure -T:build clean")}

         publish:native
         {:doc  "Publish native companion jars for the selected platforms"
          :task (let [dirs (selected-native-dirs)]
                  (sync-native-versions!)
                  (update-native! dirs)
                  (deploy-native-jars! dirs))}

         publish:all
         {:doc  "Publish native companion jars and then the main library"
          :task (let [dirs (native-dirs)]
                  (sync-native-versions!)
                  (update-native! dirs)
                  (deploy-native-jars! dirs)
                  (publish-clojars/publish!))}

         publish   {:doc     "Publish the clojure sdk libs to clojars"
                    :depends [jar]
                    :task    (publish-clojars/publish!)}}}
